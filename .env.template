# ──────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your own values.
#    cp .env.template .env
#  NEVER commit your real `.env` — it is gitignored on purpose.
# ──────────────────────────────────────────────────────────────

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram user id that gets the in-chat admin panel
ADMIN_TELEGRAM_ID=123456789

# Database (used inside the docker compose network)
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=chatbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Vector store (Qdrant) — per-user personalization memory
QDRANT_HOST=qdrant
QDRANT_PORT=6333
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
PERSONALIZATION_TOPK=4

# Web search (@web). Optional. Set both for reliable Google results
# (https://developers.google.com/custom-search/v1/introduction, free 100/day);
# leave blank to use the no-key DuckDuckGo fallback.
GOOGLE_API_KEY=
GOOGLE_CX=

# Proactive re-engagement (close idle chats, send a follow-up question)
REENGAGE_ENABLED=true
REENGAGE_INACTIVITY_HOURS=24
REENGAGE_CHECK_MINUTES=30
REENGAGE_MAX_PER_RUN=50

# App
APP_PORT=8009
DEFAULT_MODEL=gpt-4o-mini
CONTEXT_MESSAGES=12
